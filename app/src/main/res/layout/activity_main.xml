<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt;"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 하루는 어땠나요?"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="감정 우표를 선택해주세요."
            android:textSize="14sp"
            android:layout_marginTop="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
            android:textSize="11sp"
            android:layout_marginTop="16dp"/>

        <ImageView
            android:id="@+id/ivHappy"
            android:layout_width="40dp"
            android:layout_height="31dp"
            android:layout_marginTop="30dp"
            android:src="@drawable/ic_happy" />

        <TextView
            android:id="@+id/tvHappy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="더없이 행복한 하루였어요"
            android:textSize="14sp"
            android:layout_marginTop="10dp"/>

        <ImageView
            android:id="@+id/ivExcited"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_excited"
            android:layout_marginTop="30dp" />

        <TextView
            android:id="@+id/tvExcited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="들뜨고 흥분돼요"
            android:textSize="14sp"
            android:layout_marginTop="10dp"/>

        <ImageView
            android:id="@+id/ivNormal"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_normal"
            android:layout_marginTop="30dp" />

        <TextView
            android:id="@+id/tvNormal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="평범한 하루였어요"
            android:textSize="14sp"
            android:layout_marginTop="10dp"/>

        <ImageView
            android:id="@+id/ivAnxious"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_anxious"
            android:layout_marginTop="30dp" />

        <TextView
            android:id="@+id/tvAnxious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="생각이 많아지고 불안해요"
            android:textSize="14sp"
            android:layout_marginTop="10dp"/>

        <ImageView
            android:id="@+id/ivAngry"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_angry"
            android:layout_marginTop="30dp" />

        <TextView
            android:id="@+id/tvAngry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="부글부글 화가 나요"
            android:textSize="14sp"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>