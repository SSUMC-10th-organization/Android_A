<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#000000"
            android:fontFamily="@font/noto_sans_medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            app:layout_constraintTop_toTopOf="@id/iv_back"
            app:layout_constraintBottom_toBottomOf="@id/iv_back"
            app:layout_constraintStart_toEndOf="@id/iv_back"
            app:layout_constraintEnd_toStartOf="@id/iv_search" />

        <ImageView
            android:id="@+id/iv_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/iv_back"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 상품 이미지 -->
        <ImageView
            android:id="@+id/iv_detail_product"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:background="#F5F5F5"
            android:layout_marginTop="20dp"
            android:layout_marginStart="19dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toBottomOf="@id/iv_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 텍스트 전체 래퍼 -->
        <LinearLayout
            android:id="@+id/ll_text_wrapper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/iv_detail_product"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 그룹 1: 분류, 이름, 가격 -->
            <LinearLayout
                android:id="@+id/ll_product_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="35dp">

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:fontFamily="@font/noto_sans_regular"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp" />

                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="28sp"
                    android:fontFamily="@font/noto_sans_medium"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_detail_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:fontFamily="@font/noto_sans_regular"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- 그룹 2: 부가 설명 (더미 텍스트) -->
            <LinearLayout
                android:id="@+id/ll_product_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="30dp">

                <TextView
                    android:id="@+id/tv_detail_long_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DUMMY TEXT"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:fontFamily="@font/noto_sans_regular"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp" />

            </LinearLayout>

            <!-- 그룹 3: View Product Details -->
            <LinearLayout
                android:id="@+id/ll_view_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="35dp">

                <TextView
                    android:id="@+id/tv_view_product_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Product Details"
                    android:textColor="#767676"
                    android:textSize="16sp"
                    android:fontFamily="@font/noto_sans_regular"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 사이즈 선택 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_size_select"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="사이즈 선택"
            android:textColor="#000000"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_medium"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:layout_marginStart="42dp"
            android:layout_marginEnd="42dp"
            app:icon="@drawable/ic_arrow_down"
            app:iconGravity="textEnd"
            app:iconTint="@null"
            app:iconSize="0dp"
            app:iconPadding="10dp"
            app:cornerRadius="26dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/ll_text_wrapper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 장바구니에 추가 버튼 -->
        <Button
            android:id="@+id/btn_add_to_cart"
            android:layout_width="0dp"
            android:layout_height="51dp"
            android:text="장바구니에 추가"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_medium"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:backgroundTint="#000000"
            android:layout_marginStart="42dp"
            android:layout_marginEnd="42dp"
            android:layout_marginTop="20dp"
            app:cornerRadius="26dp"
            app:layout_constraintTop_toBottomOf="@id/btn_size_select"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 위시리스트 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wishlist"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="위시리스트"
            android:textColor="#000000"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_medium"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:layout_marginStart="42dp"
            android:layout_marginEnd="42dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            app:icon="@drawable/ic_heart_empty"
            app:iconGravity="textEnd"
            app:iconTint="@null"
            app:iconSize="0dp"
            app:iconPadding="10dp"
            app:cornerRadius="26dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/btn_add_to_cart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>